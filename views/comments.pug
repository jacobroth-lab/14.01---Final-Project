extends layout 

block content 
    section.comments-intro 
        h1 Share Your Thoughts 
        p Read other comments and comment your own experinces.
    
    section.comments-form 
        form(action'/comments', method='POST')
            .form-group  
                label(for='name') Your Name: 
                input(type='text', id='name', name='name', required)
        
            .form-group 
                label(for='comment') Your Comment: 
                input(type='comment', id='comment', rows='5', required)
            
            button.button(type='submit') Post Comment 
    
    section.comments-lsit 
        h2 Recent Comments 
        each comment in comments 
            article.comment
                .comment-header
                    h4= comment.name 
                    small.date = new Date(comment.created.at).toLocalDateString()
                p= comment.comment 
        .pagination
            if currentPage > 1
                a(href='/comments?page=' + (currentPage - 1)) Previous
            span Page #{currentPage} of #{totalPages}

            if currentPage < totalPages
                a(href='/comments?pages=' + (currentPage + 1)) Next
